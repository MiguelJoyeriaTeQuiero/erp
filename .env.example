# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno para docker-compose
# Copiar a .env y rellenar los valores obligatorios antes de iniciar.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Base de datos ────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tequierometales
POSTGRES_PORT=5432

# ─── JWT ── OBLIGATORIO cambiar en producción ─────────────────────────────────
# Generar con: openssl rand -base64 48
JWT_SECRET=cambia-esto-por-una-clave-aleatoria-segura-de-al-menos-32-caracteres
JWT_REFRESH_SECRET=cambia-esto-por-otra-clave-aleatoria-diferente-a-la-anterior
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=3001
FRONTEND_PORT=3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL pública del backend tal como la ve el navegador del cliente.
# Si se despliega en un servidor remoto, cambiar localhost por la IP/dominio.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Debe coincidir con la URL desde la que se accede al frontend.
CORS_ORIGIN=http://localhost:3000

# ─── Almacenamiento de archivos ───────────────────────────────────────────────
# local  → guarda en /app/uploads (montado como volumen Docker)
# s3     → requiere configurar las variables S3 de abajo
STORAGE_DRIVER=local
# STORAGE_S3_BUCKET=mi-bucket-tqmetales
# STORAGE_S3_REGION=eu-south-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=

# ─── Precios ──────────────────────────────────────────────────────────────────
# Intervalo del cron de actualización de precios (en segundos)
PRICE_UPDATE_INTERVAL_SECONDS=30
