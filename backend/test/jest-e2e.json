{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@common/(.*)": "<rootDir>/src/common/$1",
    "@modules/(.*)": "<rootDir>/src/modules/$1",
    "@domain/(.*)": "<rootDir>/src/domain/$1",
    "@storage/(.*)": "<rootDir>/src/storage/$1"
  }
}
