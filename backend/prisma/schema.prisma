generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ClientType {
  COMPANY
  INDIVIDUAL
}

enum ClosureStatus {
  DRAFT
  CONFIRMED
  WITH_ADVANCE
  PENDING_COLLECTION
  PARTIAL_COLLECTION
  PENDING_VALIDATION
  IN_VALIDATION
  WITH_INCIDENTS
  VALIDATED
  COMPLETED
  CANCELLED
}

enum CollectionStatus {
  REGISTERED
  VALIDATED
  WITH_INCIDENTS
  COMPLETED
  CANCELLED
}

enum IncidentType {
  INVALID_MATERIAL
  PENDING_COLLECTION
  DIFFERENCE
  SCRAP
  PENDING_CONVERSION
  VALIDATION_DISCREPANCY
  ADVANCE_REFUND
}

enum IncidentStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CANCELLED
}

enum ValidationStatus {
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum ConversionType {
  AUTOMATIC
  MANUAL
}

enum ConversionStatus {
  PENDING
  APPLIED
  REJECTED
}

enum PaymentMethod {
  CASH
  TRANSFER
  OTHER
}

enum DeliveryNoteStatus {
  GENERATED
  SENT
  VOIDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CONFIRM
  CANCEL
  APPROVE
  REJECT
  UPLOAD
  DOWNLOAD
  CONVERT
}

// ─── Auth & Users ─────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  createdAt   DateTime @default(now())

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique
  description String
  module      String

  roles RolePermission[]
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String
  roleId       String
  isActive     Boolean   @default(true)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  role Role @relation(fields: [roleId], references: [id])

  // Relaciones de autoría
  clientsCreated         Client[]            @relation("ClientCreatedBy")
  closuresCreated        DealClosure[]       @relation("ClosureCreatedBy")
  closuresConfirmed      DealClosure[]       @relation("ClosureConfirmedBy")
  closuresCancelled      DealClosure[]       @relation("ClosureCancelledBy")
  advancesAuthorized     AdvancePayment[]
  collectionsCollected   Collection[]
  conversionsApplied     Conversion[]
  validationSessions     ValidationSession[]
  incidentsCreated       Incident[]          @relation("IncidentCreatedBy")
  incidentsResolved      Incident[]          @relation("IncidentResolvedBy")
  deliveryNotesGenerated DeliveryNote[]
  priceRatesCreated      PriceRate[]
  documentsUploaded      ClientDocument[]
  auditLogs              AuditLog[]
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model ClientCategory {
  id              String   @id @default(uuid())
  name            String   @unique
  slug            String   @unique
  priceMultiplier Decimal  @db.Decimal(5, 4)
  description     String?
  isActive        Boolean  @default(true)
  sortOrder       Int

  clients    Client[]
  priceRates PriceRate[]
}

model MetalType {
  id        String  @id @default(uuid())
  name      String
  code      String  @unique
  isActive  Boolean @default(true)
  sortOrder Int

  karats          KaratCatalog[]
  priceRates      PriceRate[]
  closureLines    DealClosureLine[]
  collectionLines CollectionLine[]
}

model KaratCatalog {
  id          String  @id @default(uuid())
  metalTypeId String
  label       String
  purity      Decimal @db.Decimal(5, 4)
  isCommon    Boolean @default(false)
  sortOrder   Int
  isActive    Boolean @default(true)

  metalType MetalType @relation(fields: [metalTypeId], references: [id])

  priceRates         PriceRate[]
  closureLines       DealClosureLine[]
  collectionLines    CollectionLine[]
  conversionsSource  Conversion[]      @relation("ConversionSourceKarat")
  conversionsTarget  Conversion[]      @relation("ConversionTargetKarat")
  validationLines    ValidationLine[]

  @@unique([metalTypeId, label])
}

// ─── Pricing ──────────────────────────────────────────────────────────────────

model PriceRate {
  id           String    @id @default(uuid())
  metalTypeId  String
  karatId      String
  categoryId   String
  pricePerGram Decimal   @db.Decimal(12, 2)
  validFrom    DateTime
  validUntil   DateTime?
  isActive     Boolean   @default(true)
  createdById  String?
  createdAt    DateTime  @default(now())

  metalType MetalType      @relation(fields: [metalTypeId], references: [id])
  karat     KaratCatalog   @relation(fields: [karatId], references: [id])
  category  ClientCategory @relation(fields: [categoryId], references: [id])
  createdBy User?          @relation(fields: [createdById], references: [id])

  @@index([metalTypeId, karatId, categoryId, isActive])
}

// ─── Clients ──────────────────────────────────────────────────────────────────

model Client {
  id             String     @id @default(uuid())
  type           ClientType
  commercialName String
  legalName      String
  taxId          String     @unique
  phone          String
  address        String
  contactPerson  String
  categoryId     String
  isActive       Boolean    @default(true)
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  category  ClientCategory @relation(fields: [categoryId], references: [id])
  createdBy User           @relation("ClientCreatedBy", fields: [createdById], references: [id])

  documents ClientDocument[]
  closures  DealClosure[]
}

model ClientDocument {
  id           String    @id @default(uuid())
  clientId     String
  originalName String
  storedPath   String
  mimeType     String
  sizeBytes    Int
  uploadedById String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])
}

// ─── Closures ─────────────────────────────────────────────────────────────────

model DealClosure {
  id                 String        @id @default(uuid())
  code               String        @unique
  sequenceNumber     Int
  year               Int
  clientId           String
  status             ClosureStatus @default(DRAFT)
  totalAmount        Decimal       @db.Decimal(12, 2)
  advanceAmount      Decimal       @db.Decimal(12, 2) @default(0)
  finalAmount        Decimal       @db.Decimal(12, 2)
  observations       String?       @db.Text
  version            Int           @default(1)
  createdById        String
  confirmedById      String?
  confirmedAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?       @db.Text
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  client      Client  @relation(fields: [clientId], references: [id])
  createdBy   User    @relation("ClosureCreatedBy", fields: [createdById], references: [id])
  confirmedBy User?   @relation("ClosureConfirmedBy", fields: [confirmedById], references: [id])
  cancelledBy User?   @relation("ClosureCancelledBy", fields: [cancelledById], references: [id])

  lines              DealClosureLine[]
  advance            AdvancePayment?
  collections        Collection[]
  validationSessions ValidationSession[]
  incidents          Incident[]
  deliveryNote       DeliveryNote?

  @@index([status])
  @@index([clientId])
  @@index([year, sequenceNumber])
}

model DealClosureLine {
  id             String   @id @default(uuid())
  closureId      String
  metalTypeId    String
  karatId        String
  grams          Decimal  @db.Decimal(10, 2)
  pricePerGram   Decimal  @db.Decimal(12, 2)
  lineAmount     Decimal  @db.Decimal(12, 2)
  puritySnapshot Decimal  @db.Decimal(5, 4)
  sortOrder      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  closure   DealClosure  @relation(fields: [closureId], references: [id], onDelete: Cascade)
  metalType MetalType    @relation(fields: [metalTypeId], references: [id])
  karat     KaratCatalog @relation(fields: [karatId], references: [id])

  conversions     Conversion[]
  validationLines ValidationLine[]
}

// ─── Advance Payments ─────────────────────────────────────────────────────────

model AdvancePayment {
  id                   String        @id @default(uuid())
  closureId            String        @unique
  amount               Decimal       @db.Decimal(12, 2)
  paymentMethod        PaymentMethod
  pricePerGramSnapshot Decimal       @db.Decimal(12, 2)
  gramsSnapshot        Decimal       @db.Decimal(10, 2)
  authorizedById       String
  observations         String?       @db.Text
  createdAt            DateTime      @default(now())
  cancelledAt          DateTime?

  closure      DealClosure @relation(fields: [closureId], references: [id], onDelete: Cascade)
  authorizedBy User        @relation(fields: [authorizedById], references: [id])
}

// ─── Collections ──────────────────────────────────────────────────────────────

model Collection {
  id           String           @id @default(uuid())
  closureId    String
  status       CollectionStatus @default(REGISTERED)
  collectorId  String
  observations String?          @db.Text
  isPartial    Boolean
  collectedAt  DateTime
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  closure   DealClosure @relation(fields: [closureId], references: [id], onDelete: Cascade)
  collector User        @relation(fields: [collectorId], references: [id])

  lines              CollectionLine[]
  validationSessions ValidationSession[]
  incidents          Incident[]
}

model CollectionLine {
  id             String   @id @default(uuid())
  collectionId   String
  metalTypeId    String
  karatId        String
  gramsDeclared  Decimal  @db.Decimal(10, 2)
  puritySnapshot Decimal  @db.Decimal(5, 4)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  collection Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  metalType  MetalType    @relation(fields: [metalTypeId], references: [id])
  karat      KaratCatalog @relation(fields: [karatId], references: [id])

  conversions     Conversion[]
  validationLines ValidationLine[]
}

// ─── Conversions ──────────────────────────────────────────────────────────────

model Conversion {
  id               String           @id @default(uuid())
  collectionLineId String
  closureLineId    String
  sourceKaratId    String
  targetKaratId    String
  sourceGrams      Decimal          @db.Decimal(10, 2)
  sourcePurity     Decimal          @db.Decimal(5, 4)
  targetPurity     Decimal          @db.Decimal(5, 4)
  equivalentGrams  Decimal          @db.Decimal(10, 2)
  conversionType   ConversionType
  status           ConversionStatus @default(PENDING)
  observation      String?          @db.Text
  appliedById      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  collectionLine CollectionLine  @relation(fields: [collectionLineId], references: [id], onDelete: Cascade)
  closureLine    DealClosureLine @relation(fields: [closureLineId], references: [id])
  sourceKarat    KaratCatalog    @relation("ConversionSourceKarat", fields: [sourceKaratId], references: [id])
  targetKarat    KaratCatalog    @relation("ConversionTargetKarat", fields: [targetKaratId], references: [id])
  appliedBy      User?           @relation(fields: [appliedById], references: [id])
}

// ─── Validations ──────────────────────────────────────────────────────────────

model ValidationSession {
  id           String           @id @default(uuid())
  collectionId String?
  closureId    String
  validatorId  String
  status       ValidationStatus @default(IN_PROGRESS)
  observations String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  collection Collection?  @relation(fields: [collectionId], references: [id])
  closure    DealClosure  @relation(fields: [closureId], references: [id], onDelete: Cascade)
  validator  User         @relation(fields: [validatorId], references: [id])

  lines     ValidationLine[]
  incidents Incident[]
}

model ValidationLine {
  id               String   @id @default(uuid())
  sessionId        String
  closureLineId    String?
  collectionLineId String?
  gramsValidated   Decimal  @db.Decimal(10, 2)
  karatValidatedId String
  purityValidated  Decimal  @db.Decimal(5, 4)
  observation      String?  @db.Text
  createdAt        DateTime @default(now())

  session        ValidationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  closureLine    DealClosureLine?  @relation(fields: [closureLineId], references: [id])
  collectionLine CollectionLine?   @relation(fields: [collectionLineId], references: [id])
  karatValidated KaratCatalog      @relation(fields: [karatValidatedId], references: [id])
}

// ─── Incidents ────────────────────────────────────────────────────────────────

model Incident {
  id                  String         @id @default(uuid())
  closureId           String
  collectionId        String?
  validationSessionId String?
  type                IncidentType
  status              IncidentStatus @default(OPEN)
  reason              String         @db.Text
  resolution          String?        @db.Text
  resolvedById        String?
  resolvedAt          DateTime?
  createdById         String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  closure           DealClosure        @relation(fields: [closureId], references: [id], onDelete: Cascade)
  collection        Collection?        @relation(fields: [collectionId], references: [id])
  validationSession ValidationSession? @relation(fields: [validationSessionId], references: [id])
  resolvedBy        User?              @relation("IncidentResolvedBy", fields: [resolvedById], references: [id])
  createdBy         User               @relation("IncidentCreatedBy", fields: [createdById], references: [id])
}

// ─── Delivery Notes ───────────────────────────────────────────────────────────

model DeliveryNote {
  id            String             @id @default(uuid())
  closureId     String             @unique
  code          String             @unique
  filePath      String
  status        DeliveryNoteStatus @default(GENERATED)
  generatedById String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  closure     DealClosure @relation(fields: [closureId], references: [id], onDelete: Cascade)
  generatedBy User        @relation(fields: [generatedById], references: [id])
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  userId     String
  entityType String
  entityId   String
  action     AuditAction
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
